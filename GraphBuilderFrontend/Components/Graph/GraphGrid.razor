@using GraphBuilderFrontend.Utils
@using GraphBuilderShared.Models

@{
    var (gridLines, _, _) = GeometryUtils.CalculateGrid(Viewport);
}

@foreach (var line in gridLines)
{
    <line x1="@line.X1.ToString("0")"
          y1="@line.Y1.ToString("0")"
          x2="@line.X2.ToString("0")"
          y2="@line.Y2.ToString("0")"
          stroke="#e0e0e0"
          stroke-width="1"
          stroke-opacity="0.7" />
}

@code {
    [Parameter] public ViewportState Viewport { get; set; } = null!;
}