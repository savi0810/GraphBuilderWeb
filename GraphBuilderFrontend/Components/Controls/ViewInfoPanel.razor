@using GraphBuilderFrontend.Components.Common
@using GraphBuilderShared.Models

<Card Style="border: none;"
      HeaderTitle="📋 Текущий вид"
      BodyClass="p-3">
    
    <div class="small">
        <div class="d-flex justify-content-between mb-1">
            <span class="text-muted">X:</span>
            <span class="text-dark">[@Viewport.MinX.ToString("F2"), @Viewport.MaxX.ToString("F2")]</span>
        </div>
        <div class="d-flex justify-content-between">
            <span class="text-muted">Y:</span>
            <span class="text-dark">[@Viewport.MinY.ToString("F2"), @Viewport.MaxY.ToString("F2")]</span>
        </div>
    </div>
</Card>

@code {
    [Parameter] public ViewportState Viewport { get; set; } = null!;
}