<button type="button"
        class="@GetButtonClasses()"
        @onclick="HandleClick"
        disabled="@Disabled"
        title="@Title"
        style="@Style">
    @if (!string.IsNullOrEmpty(Icon))
    {
        <span class="me-1">@Icon</span>
    }
    @if (!string.IsNullOrEmpty(Text))
    {
        @Text
    }
    @if (ChildContent != null)
    {
        @ChildContent
    }
</button>

@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public string Variant { get; set; } = "Primary";
    [Parameter] public string Size { get; set; } = "Medium";
    [Parameter] public string Class { get; set; } = string.Empty;
    [Parameter] public string Icon { get; set; } = string.Empty;
    [Parameter] public string Text { get; set; } = string.Empty;
    [Parameter] public string Title { get; set; } = string.Empty;
    [Parameter] public string Style { get; set; } = string.Empty; 
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public EventCallback OnClick { get; set; }

    private string GetButtonClasses()
    {
        var classes = new List<string> { "btn" };
        classes.Add($"btn-{Variant.ToLower()}");
        if (Size == "Small") classes.Add("btn-sm");
        else if (Size == "Large") classes.Add("btn-lg");
        if (!string.IsNullOrEmpty(Class)) classes.Add(Class);
        return string.Join(" ", classes);
    }

    private async Task HandleClick()
    {
        if (!Disabled) await OnClick.InvokeAsync();
    }
}